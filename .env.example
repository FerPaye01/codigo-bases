# --- CONFIGURACIÓN DE BASE DE DATOS (MVP ASISTENTE DE BASES ESTÁNDAR) ---
# Tipo de base de datos: 'sqlite' o 'oracle'
DB_TYPE=sqlite

# Configuración de SQLite (usado si DB_TYPE=sqlite)
SQLITE_DB_FILE=bases_osinergmin.db

# Configuración de Oracle Database (usado si DB_TYPE=oracle)
ORACLE_DB_USER=mi_usuario_desarrollo
ORACLE_DB_PASSWORD=mi_contrasena
ORACLE_DB_HOST=localhost
ORACLE_DB_PORT=1521
ORACLE_DB_SERVICE=ORCL
# Configuración de Qdrant (Base de datos vectorial)
QDRANT_DB_PATH=qdrant_db

